# .env.example
# Copy this file to your Render Environment Variables dashboard

# Django Secret Key (Generate a random string)
SECRET_KEY=your-super-secret-key-here

# Python Version (Render uses this)
PYTHON_VERSION=3.10.12

# Django Settings Module
DJANGO_SETTINGS_MODULE=BinaryImageQNN.settings

# Allowed Hosts (Render provides RENDER_EXTERNAL_HOSTNAME automatically)
# Add any additional hosts here if needed
